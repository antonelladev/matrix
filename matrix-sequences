/* Limpia el buffer de entrada para evitar bucles infinitos
   cuando el usuario ingresa texto donde se espera un número. */
void limpiarBuffer() {
    cin.clear();
    cin.ignore(numeric_limits<streamsize>::max(), '\n');
}

/* Lee un entero con validación. Muestra 'prompt' y repite
   hasta que el usuario ingrese un número entero válido. */
int leerEntero(const string& prompt) {
    int valor;
    while (true) {
        cout << prompt;
        if (cin >> valor) {
            limpiarBuffer();
            return valor;
        }
        cout << "  [!] Entrada inválida. Ingrese un número entero.\n";
        limpiarBuffer();
    }
}

/* Lee un entero dentro del rango [minVal, maxVal]. */
int leerEnteroRango(const string& prompt, int minVal, int maxVal) {
    int valor;
    while (true) {
        valor = leerEntero(prompt);
        if (valor >= minVal && valor <= maxVal)
            return valor;
        cout << "  [!] Debe estar entre " << minVal << " y " << maxVal << ".\n";
    }
}

/* Lee un double con validación. */
double leerDouble(const string& prompt) {
    double valor;
    while (true) {
        cout << prompt;
        if (cin >> valor) {
            limpiarBuffer();
            return valor;
        }
        cout << "  [!] Entrada inválida. Ingrese un número real.\n";
        limpiarBuffer();
    }
}

/* Imprime una línea separadora decorativa. */
void separador(char c = '=', int largo = 60) {
    cout << string(largo, c) << "\n";
}

/* Pausa hasta que el usuario presione Enter. */
void pausar() {
    cout << "\n  Presione Enter para continuar...";
    limpiarBuffer();
    cin.get();
}

