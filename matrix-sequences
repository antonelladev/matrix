/* SUMA DE MATRICES
   Precondición: ambas matrices deben tener las mismas dimensiones.
   Si no cumplen la condición se informa al usuario. */
void sumaMatrices() {
    separador();
    cout << "  SUMA DE MATRICES\n";
    separador('-', 40);

    // 1) Pedir dimensiones de ambas matrices ANTES de los elementos
    int filasA = leerEnteroRango("  Filas de A: ", 1, 10);
    int colsA  = leerEnteroRango("  Columnas de A: ", 1, 10);
    int filasB = leerEnteroRango("  Filas de B: ", 1, 10);
    int colsB  = leerEnteroRango("  Columnas de B: ", 1, 10);

    // 2) Verificar dimensiones compatibles ANTES de ingresar elementos
    if (filasA != filasB || colsA != colsB) {
        cout << "  [ERROR] Las matrices deben tener las mismas dimensiones para sumarse.\n";
        cout << "  A es " << filasA << "x" << colsA
             << " y B es " << filasB << "x" << colsB << ".\n";
        pausar();
        return;
    }

    // 3) Solo si las dimensiones coinciden se piden los elementos
    Matriz A = ingresarMatrizConDim("A", filasA, colsA);
    Matriz B = ingresarMatrizConDim("B", filasB, colsB);

    // 4) Calcular suma elemento a elemento
    int f = filasA, c = colsA;
    Matriz R = crearMatriz(f, c);
    for (int i = 0; i < f; i++)
        for (int j = 0; j < c; j++)
            R[i][j] = A[i][j] + B[i][j];

    cout << "\n  Resultado A + B:\n";
    mostrarMatriz(R);
    pausar();
}

/* RESTA DE MATRICES
   Precondición: mismas dimensiones. */
void restaMatrices() {
    separador();
    cout << "  RESTA DE MATRICES\n";
    separador('-', 40);

    // 1) Pedir dimensiones de ambas matrices ANTES de los elementos
    int filasA = leerEnteroRango("  Filas de A: ", 1, 10);
    int colsA  = leerEnteroRango("  Columnas de A: ", 1, 10);
    int filasB = leerEnteroRango("  Filas de B: ", 1, 10);
    int colsB  = leerEnteroRango("  Columnas de B: ", 1, 10);

    // 2) Verificar dimensiones compatibles ANTES de ingresar elementos
    if (filasA != filasB || colsA != colsB) {
        cout << "  [ERROR] Las matrices deben tener las mismas dimensiones para restarse.\n";
        cout << "  A es " << filasA << "x" << colsA
             << " y B es " << filasB << "x" << colsB << ".\n";
        pausar();
        return;
    }

    // 3) Solo si las dimensiones coinciden se piden los elementos
    Matriz A = ingresarMatrizConDim("A", filasA, colsA);
    Matriz B = ingresarMatrizConDim("B", filasB, colsB);

    // 4) Calcular resta elemento a elemento
    int f = filasA, c = colsA;
    Matriz R = crearMatriz(f, c);
    for (int i = 0; i < f; i++)
        for (int j = 0; j < c; j++)
            R[i][j] = A[i][j] - B[i][j];

    cout << "\n  Resultado A - B:\n";
    mostrarMatriz(R);
    pausar();
}

/* MULTIPLICACIÓN DE MATRICES (implementada manualmente)
   Para multiplicar A (m×n) por B (n×p), el número de columnas
   de A debe ser igual al número de filas de B.
   Fórmula: R[i][j] = Σ A[i][k] * B[k][j]  para k = 0..n-1  */
void multiplicacionMatrices() {
    separador();
    cout << "  MULTIPLICACIÓN DE MATRICES\n";
    separador('-', 40);
    Matriz A = ingresarMatriz("A");
    Matriz B = ingresarMatriz("B");

    // Condición de compatibilidad: cols(A) == filas(B)
    if (cols(A) != filas(B)) {
        cout << "  [ERROR] El número de columnas de A (" << cols(A)
             << ") debe ser igual al número de filas de B (" << filas(B) << ").\n";
        pausar();
        return;
    }

    int m = filas(A), n = cols(A), p = cols(B);
    Matriz R = crearMatriz(m, p);

    // Producto punto de cada fila de A con cada columna de B
    for (int i = 0; i < m; i++)
        for (int j = 0; j < p; j++)
            for (int k = 0; k < n; k++)
                R[i][j] += A[i][k] * B[k][j];

    cout << "\n  Resultado A × B:\n";
    mostrarMatriz(R);
    pausar();
}

/* TRANSPUESTA DE UNA MATRIZ (implementada manualmente)
   La transpuesta de A (m×n) es A^T (n×m) donde A^T[j][i] = A[i][j]. */
void transpuestaMatriz() {
    separador();
    cout << "  TRANSPUESTA DE MATRIZ\n";
    separador('-', 40);
    Matriz A = ingresarMatriz("A");

    int f = filas(A), c = cols(A);
    Matriz T = crearMatriz(c, f);  // dimensiones invertidas

    for (int i = 0; i < f; i++)
        for (int j = 0; j < c; j++)
            T[j][i] = A[i][j];   // intercambio de índices

    cout << "\n  Matriz original:\n";
    mostrarMatriz(A);
    cout << "\n  Transpuesta A^T:\n";
    mostrarMatriz(T);
    pausar();
}

// ============================================================
//  MÓDULO 1-B: ANÁLISIS DE PROPIEDADES DE UNA MATRIZ
// ============================================================

/* Verifica si la matriz es CUADRADA (filas == columnas). */
bool esCuadrada(const Matriz& m) {
    return filas(m) == cols(m);
}

/* Verifica si la matriz es DIAGONAL:
   Una matriz cuadrada es diagonal si todos los elementos
   fuera de la diagonal principal son cero.
   Condición: m[i][j] == 0 para todo i ≠ j. */
bool esDiagonal(const Matriz& m) {
    if (!esCuadrada(m)) return false;
    int n = filas(m);
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            if (i != j && fabs(m[i][j]) > 1e-9)
                return false;
    return true;
}

/* Verifica si la matriz es IDENTIDAD:
   Diagonal con todos los elementos de la diagonal igual a 1. */
bool esIdentidad(const Matriz& m) {
    if (!esDiagonal(m)) return false;
    int n = filas(m);
    for (int i = 0; i < n; i++)
        if (fabs(m[i][i] - 1.0) > 1e-9)
            return false;
    return true;
}

/* Verifica si la matriz es TRIANGULAR SUPERIOR:
   Todos los elementos debajo de la diagonal principal son cero.
   Condición: m[i][j] == 0 para todo i > j. */
bool esTriangularSuperior(const Matriz& m) {
    if (!esCuadrada(m)) return false;
    int n = filas(m);
    for (int i = 1; i < n; i++)          // i empieza en 1 (segunda fila)
        for (int j = 0; j < i; j++)       // j < i → debajo de la diagonal
            if (fabs(m[i][j]) > 1e-9)
                return false;
    return true;
}

/* Verifica si la matriz es TRIANGULAR INFERIOR:
   Todos los elementos encima de la diagonal principal son cero.
   Condición: m[i][j] == 0 para todo i < j. */
bool esTriangularInferior(const Matriz& m) {
    if (!esCuadrada(m)) return false;
    int n = filas(m);
    for (int i = 0; i < n - 1; i++)       // i va hasta penúltima fila
        for (int j = i + 1; j < n; j++)   // j > i → encima de la diagonal
            if (fabs(m[i][j]) > 1e-9)
                return false;
    return true;
}

/* Muestra el análisis completo de propiedades de una matriz. */
void analisisMatriz() {
    separador();
    cout << "  ANÁLISIS DE PROPIEDADES\n";
    separador('-', 40);
    Matriz A = ingresarMatriz("A");

    cout << "\n  Matriz ingresada:\n";
    mostrarMatriz(A);
    cout << "\n  --- Resultados ---\n";
    cout << "  Cuadrada:            " << (esCuadrada(A)          ? "SI" : "NO") << "\n";
    cout << "  Diagonal:            " << (esDiagonal(A)          ? "SI" : "NO") << "\n";
    cout << "  Identidad:           " << (esIdentidad(A)         ? "SI" : "NO") << "\n";
    cout << "  Triangular Superior: " << (esTriangularSuperior(A) ? "SI" : "NO") << "\n";
    cout << "  Triangular Inferior: " << (esTriangularInferior(A) ? "SI" : "NO") << "\n";
    pausar();
}

