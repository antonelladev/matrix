/* DETERMINANTE 2×2 (regla de Sarrus simplificada):
   |a b|
   |c d| = a*d - b*c                                         */
double determinante2x2(const Matriz& m) {
    return m[0][0] * m[1][1] - m[0][1] * m[1][0];
}

/* DETERMINANTE 3×3 (regla de Sarrus):
   Suma de los productos de las diagonales principales
   menos la suma de las diagonales secundarias.
   det = a(ei−fh) − b(di−fg) + c(dh−eg)
   donde la matriz es:
   | a b c |
   | d e f |
   | g h i |                                                  */
double determinante3x3(const Matriz& m) {
    double a = m[0][0], b = m[0][1], c = m[0][2];
    double d = m[1][0], e = m[1][1], f = m[1][2];
    double g = m[2][0], h = m[2][1], i = m[2][2];

    return a*(e*i - f*h) - b*(d*i - f*g) + c*(d*h - e*g);
}

/* Menú de cálculo de determinantes. */
void calcularDeterminante() {
    separador();
    cout << "  CÁLCULO DE DETERMINANTE\n";
    separador('-', 40);
    cout << "  Seleccione el orden:\n";
    cout << "    1. Matriz 2x2\n";
    cout << "    2. Matriz 3x3\n";
    int op = leerEnteroRango("  Opción: ", 1, 2);

    if (op == 1) {
        // Ingresar manualmente la matriz 2x2
        Matriz m = crearMatriz(2, 2);
        cout << "  Ingrese los 4 elementos de la matriz 2x2:\n";
        for (int i = 0; i < 2; i++)
            for (int j = 0; j < 2; j++)
                m[i][j] = leerDouble("    m[" + to_string(i+1) + "]["
                                     + to_string(j+1) + "] = ");
        cout << "\n  Matriz ingresada:\n";
        mostrarMatriz(m);
        cout << "\n  Determinante = " << formatoNumero(determinante2x2(m)) << "\n";

    } else {
        // Ingresar manualmente la matriz 3x3
        Matriz m = crearMatriz(3, 3);
        cout << "  Ingrese los 9 elementos de la matriz 3x3:\n";
        for (int i = 0; i < 3; i++)
            for (int j = 0; j < 3; j++)
                m[i][j] = leerDouble("    m[" + to_string(i+1) + "]["
                                     + to_string(j+1) + "] = ");
        cout << "\n  Matriz ingresada:\n";
        mostrarMatriz(m);
        cout << "\n  Determinante = " << formatoNumero(determinante3x3(m)) << "\n";
    }
    pausar();
}

// ============================================================
//  MÓDULO 2: SUCESIONES Y SERIES
//
//  Fórmulas implementadas:
//   1. Aritmética:    a(n) = a1 + (n-1)*d
//   2. Geométrica:    a(n) = a1 * r^(n-1)
//   3. Fibonacci:     a(n) = a(n-1) + a(n-2),  a(1)=a1, a(2)=a2
//   4. Cuadrados:     a(n) = n²
//   5. Armónica:      a(n) = 1/n
//   6. Exponencial:   a(n) = a * b^n
// ============================================================

/* Calcula potencia entera b^exp de forma iterativa (sin pow)
   para evitar dependencia innecesaria. Se usa pow() de <cmath>
   solo para la sucesión exponencial con base double. */
double potencia(double base, int exp) {
    if (exp == 0) return 1.0;
    double resultado = 1.0;
    bool negativo = (exp < 0);
    int e = negativo ? -exp : exp;
    for (int i = 0; i < e; i++)
        resultado *= base;
    return negativo ? (1.0 / resultado) : resultado;
}

/* Calcula el término n-ésimo de la sucesión seleccionada.
   'tipo': 1=aritmética, 2=geométrica, 3=fibonacci,
           4=cuadrados, 5=armónica, 6=exponencial.
   Los parámetros se pasan como vector<double>:
     [0]=a1, [1]=d/r/a2/a/b según el tipo.              */
double terminoSucesion(int tipo, int n, const vector<double>& p,
                        const vector<double>& fib) {
    switch (tipo) {
        case 1: return p[0] + (n - 1) * p[1];          // aritmética
        case 2: return p[0] * potencia(p[1], n - 1);   // geométrica
        case 3: return fib[n - 1];                      // fibonacci (precalculado)
        case 4: return (double)n * n;                   // cuadrados perfectos
        case 5: return (n == 0) ? 0.0 : 1.0 / n;       // armónica
        case 6: return p[0] * pow(p[1], n);             // exponencial
        default: return 0.0;
    }
}

/* Módulo principal de Sucesiones y Series. */
void moduloSucesiones() {
    separador();
    cout << "  SUCESIONES Y SERIES\n";
    separador('-', 40);
    cout << "  Seleccione la sucesión:\n";
    cout << "    1. Aritmética       a(n) = a1 + (n-1)*d\n";
    cout << "    2. Geométrica       a(n) = a1 * r^(n-1)\n";
    cout << "    3. Fibonacci        a(n) = a(n-1) + a(n-2)\n";
    cout << "    4. Cuadrados perf.  a(n) = n²\n";
    cout << "    5. Armónica         a(n) = 1/n\n";
    cout << "    6. Exponencial      a(n) = a * b^n\n";
    int tipo = leerEnteroRango("  Opción: ", 1, 6);

    // Parámetros de la sucesión
    vector<double> p(3, 0.0);   // parámetros genéricos
    int N = 0;                  // cantidad de términos a generar

    // Solicitar parámetros según el tipo elegido
    switch (tipo) {
        case 1:
            p[0] = leerDouble("  Primer término (a1): ");
            p[1] = leerDouble("  Razón común (d): ");
            break;
        case 2:
            p[0] = leerDouble("  Primer término (a1): ");
            p[1] = leerDouble("  Razón común (r): ");
            if (fabs(p[0]) < 1e-12) {
                cout << "  [!] a1 no puede ser 0 en una sucesión geométrica.\n";
                pausar(); return;
            }
            break;
        case 3:
            p[0] = leerDouble("  Primer término a(1): ");
            p[1] = leerDouble("  Segundo término a(2): ");
            break;
        case 4:
            // No requiere parámetros adicionales
            break;
        case 5:
            // No requiere parámetros
            break;
        case 6:
            p[0] = leerDouble("  Coeficiente (a): ");
            p[1] = leerDouble("  Base (b): ");
            break;
    }
    N = leerEnteroRango("  Cantidad de términos n: ", 1, 200);

    // Precalcular Fibonacci si aplica
    vector<double> fib(N, 0.0);
    if (tipo == 3 && N >= 1) {
        fib[0] = p[0];
        if (N >= 2) fib[1] = p[1];
        for (int i = 2; i < N; i++)
            fib[i] = fib[i-1] + fib[i-2];
    }

    // --- i. Generar y mostrar los primeros N términos ---
    cout << "\n  --- Términos de la sucesión ---\n";
    double sumaParcial = 0.0;
    vector<double> terminos(N);

    for (int n = 1; n <= N; n++) {
        double t = terminoSucesion(tipo, n, p, fib);
        terminos[n-1] = t;
        sumaParcial += t;

        // Mostrar hasta 50 términos en pantalla para no saturar
        if (N <= 50) {
            cout << "  a(" << setw(3) << n << ") = "
                 << fixed << setprecision(6) << t << "\n";
        }
    }
    if (N > 50) {
        cout << "  [Se generaron " << N << " términos. "
             << "Mostrando primero, últimos 5 y total.]\n";
        cout << "  a(1) = " << fixed << setprecision(6) << terminos[0] << "\n";
        cout << "  ...\n";
        for (int i = N - 5; i < N; i++)
            cout << "  a(" << i+1 << ") = " << terminos[i] << "\n";
    }

    // --- iii. Suma parcial ---
    cout << "\n  --- Suma de los primeros " << N << " términos ---\n";
    cout << "  S(" << N << ") = " << fixed << setprecision(6) << sumaParcial << "\n";

    // --- iv. Aproximación al límite ---
    cout << "\n  --- Comportamiento de la sucesión ---\n";

    if (N >= 5) {
        // Comparar los últimos 5 términos para detectar tendencia
        double ult  = terminos[N-1];
        double penU = terminos[N-2];
        double dif1 = fabs(ult - penU);
        double dif2 = (N >= 3) ? fabs(terminos[N-2] - terminos[N-3]) : dif1 + 1;

        if (dif1 < 1e-6) {
            cout << "  Los términos parecen converger a ≈ "
                 << fixed << setprecision(8) << ult << "\n";
        } else if (dif1 > dif2 && dif2 > 0) {
            cout << "  Los términos parecen DIVERGIR (crecen sin límite).\n";
        } else if (dif1 < dif2) {
            cout << "  Los diferencias disminuyen; podría converger a ≈ "
                 << fixed << setprecision(8) << ult << "\n";
        } else {
            cout << "  Comportamiento oscilante o constante.\n";
        }

        // Análisis específico por tipo
        switch (tipo) {
            case 1:
                if (fabs(p[1]) < 1e-9)
                    cout << "  Sucesión constante, límite exacto = " << p[0] << "\n";
                else
                    cout << "  Sucesión aritmética diverge (d ≠ 0).\n";
                break;
            case 2:
                if (fabs(p[1]) < 1.0)
                    cout << "  |r| < 1: la sucesión converge a 0.\n";
                else if (fabs(p[1]) > 1.0)
                    cout << "  |r| > 1: la sucesión diverge.\n";
                else
                    cout << "  |r| = 1: sucesión constante.\n";
                break;
            case 3:
                cout << "  Fibonacci crece sin límite (diverge).\n";
                break;
            case 4:
                cout << "  Sucesión n² diverge a infinito.\n";
                break;
            case 5:
                cout << "  a(n) = 1/n converge a 0, pero su serie Σ1/n diverge (serie armónica).\n";
                break;
            case 6:
                if (fabs(p[1]) < 1.0)
                    cout << "  |b| < 1: la sucesión converge a 0.\n";
                else
                    cout << "  |b| >= 1: la sucesión diverge.\n";
                break;
        }
    } else {
        cout << "  (Se necesitan más términos para un análisis de convergencia confiable.)\n";
    }

    pausar();
}

