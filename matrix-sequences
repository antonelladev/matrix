//  TIPO MATRIZ: vector<vector<double>>
//  Todas las funciones de matrices operan sobre este tipo.
// ============================================================
typedef vector<vector<double>> Matriz;

/* Crea una matriz de filas x cols inicializada en 0. */
Matriz crearMatriz(int filas, int cols) {
    return Matriz(filas, vector<double>(cols, 0.0));
}

/* Solicita al usuario que ingrese los elementos de la matriz. */
Matriz ingresarMatriz(const string& nombre) {
    int filas = leerEnteroRango("  Filas de " + nombre + ": ", 1, 10);
    int cols  = leerEnteroRango("  Columnas de " + nombre + ": ", 1, 10);
    Matriz m  = crearMatriz(filas, cols);
    cout << "  Ingrese los elementos fila por fila:\n";
    for (int i = 0; i < filas; i++)
        for (int j = 0; j < cols; j++)
            m[i][j] = leerDouble("    " + nombre + "[" + to_string(i+1) + "]["
                                 + to_string(j+1) + "] = ");
    return m;
}

/* Solicita los elementos de una matriz cuyas dimensiones (filas x cols)
   ya fueron determinadas previamente. Se usa en suma y resta, donde las
   dimensiones se validan ANTES de pedir los elementos. */
Matriz ingresarMatrizConDim(const string& nombre, int filas, int cols) {
    Matriz m = crearMatriz(filas, cols);
    cout << "  Ingrese los elementos de " << nombre << " fila por fila:\n";
    for (int i = 0; i < filas; i++)
        for (int j = 0; j < cols; j++)
            m[i][j] = leerDouble("    " + nombre + "[" + to_string(i+1) + "]["
                                 + to_string(j+1) + "] = ");
    return m;
}

/* Da formato a un número: si es un entero exacto se muestra sin
   decimales (ej. 5 en vez de 5.0000); si tiene parte decimal se
   muestra con hasta 4 decimales, eliminando ceros sobrantes
   (ej. 2.5 en vez de 2.5000). */
string formatoNumero(double valor) {
    // Redondear a 4 decimales para evitar ruido de punto flotante
    double redondeado = round(valor * 10000.0) / 10000.0;

    if (fabs(redondeado - round(redondeado)) < 1e-9) {
        // Es un entero exacto
        long long entero = (long long) round(redondeado);
        return to_string(entero);
    }

    // Tiene decimales: formatear con 4 y quitar ceros finales
    ostringstream oss;
    oss << fixed << setprecision(4) << redondeado;
    string s = oss.str();

    // Quitar ceros sobrantes al final, sin dejar un punto suelto
    size_t puntoPos = s.find('.');
    if (puntoPos != string::npos) {
        size_t ultimo = s.find_last_not_of('0');
        if (ultimo == puntoPos) ultimo--;  // quitar también el punto
        s.erase(ultimo + 1);
    }
    return s;
}

/* Muestra una matriz con formato alineado. */
void mostrarMatriz(const Matriz& m, const string& nombre = "") {
    if (!nombre.empty()) cout << "  " << nombre << ":\n";
    int filas = m.size();
    int cols  = (filas > 0) ? m[0].size() : 0;
    for (int i = 0; i < filas; i++) {
        cout << "  [ ";
        for (int j = 0; j < cols; j++)
            cout << setw(10) << formatoNumero(m[i][j]) << " ";
        cout << "]\n";
    }
}

/* Devuelve el número de filas de la matriz. */
int filas(const Matriz& m) { return (int)m.size(); }

/* Devuelve el número de columnas de la matriz. */
int cols(const Matriz& m) { return (m.size() > 0) ? (int)m[0].size() : 0; }

